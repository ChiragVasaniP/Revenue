<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Session.Lib" parent="Theme.Material3.Light.NoActionBar"/>
    <style name="AdAttribution">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">left</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">12sp</item>
        <item name="android:text">@string/ad_attribution</item>
        <item name="android:background">@color/color_ffcc66</item>
        <item name="android:width">15dp</item>
        <item name="android:height">15dp</item>
    </style>

    <!-- Add to your styles.xml -->
    <style name="RoundedDialogTheme" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <!-- Rounded corners -->
        <item name="dialogCornerRadius">16dp</item>

        <!-- Transparent background if needed -->
        <item name="android:windowBackground">@android:color/transparent</item>

        <!-- Keep dialog floating -->
        <item name="android:windowIsFloating">true</item>

        <!-- Optional: avoid full screen width -->
        <item name="android:layout_width">wrap_content</item>
    </style>


    <style name="Widget.MyApp.LoadingCard" parent="">
        <item name="cardBackgroundColor">?attr/customCardBackgroundColor</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="dialogCornerRadius">16dp</item>

        <!-- Transparent background if needed -->
        <item name="android:windowBackground">@android:color/transparent</item>

        <!-- Keep dialog floating -->
<!--        <item name="android:windowIsFloating">true</item>-->
        <item name="android:windowMinWidthMajor">50%</item>
        <item name="android:windowMinWidthMinor">50%</item>
        <!-- Optional: avoid full screen width -->
        <item name="android:layout_width">wrap_content</item>
        <item name="cardElevation">4dp</item>
    </style>

    <!-- Text style -->
    <style name="Text.MyApp.LoadingMessage" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/customTextColor</item>
        <item name="android:gravity">center</item>
    </style>


    <style name="Session.Lib.Dialog.Animation" parent="">
        <item name="android:windowEnterAnimation">@anim/session_lib_dialog_enter</item>
        <item name="android:windowExitAnimation">@anim/session_lib_dialog_exit</item>
    </style>



    <style name="SessionLibTheme" parent="Theme.Session.Lib">
        <item name="sessionLibBackground">@drawable/session_lib_window_background</item>
        <item name="sessionLibSmallViewBackground">@drawable/session_lib_small_view_background</item>
        <item name="sessionLibIconClose">@drawable/session_lib_close</item>
        <item name="sessionLibIconLogo">@drawable/session_lib_app_logo</item>
        <item name="sessionLibIconEndSession">@drawable/session_lib_icon_end_session</item>
        <item name="sessionLibIconReward">@drawable/session_lib_icon_reward</item>
        <item name="sessionLibIconMilestoneReward">?attr/sessionLibIconReward</item>
        <item name="sessionLibIconLevelUp">@drawable/session_lib_level_up</item>
        <item name="sessionLibIconNightSessionLevelUp">?attr/sessionLibIconLevelUp</item>
        <item name="sessionLibIconRevenueEarnMore">@drawable/session_lib_double_revenue_earn_more</item>
        <item name="sessionLibIconRevenueDownloadFeature">@drawable/session_lib_double_revenue_download_feature</item>
        <item name="sessionLibIconRevenueReferralProgram">@drawable/session_lib_double_revenue_referral_program</item>

        <item name="sessionLibSeparator">@drawable/session_lib_separator_dot</item>
        <item name="sessionLibHighlightPrimaryColor">@color/sessionLibTextColorPrimary</item>
        <item name="sessionLibHighlightSecondaryColor">@color/sessionLibTextColorPrimaryInverse</item>
        <item name="sessionLibNightSessionBackground">@drawable/session_lib_night_session_background</item>
        <item name="sessionLibNightSessionListBackground">@drawable/session_lib_night_session_list_background</item>
        <item name="sessionLibNightSessionIconChargeUp">@drawable/session_lib_night_session_charge_up</item>
        <item name="sessionLibNightSessionIconDoubleEarning">@drawable/session_lib_night_session_double_earning</item>
        <item name="sessionLibHighlightBoldFontFamily">@font/session_lib_primary_font_bold</item>
        <item name="sessionLibNewAppsListBackground">@drawable/session_lib_new_app_background</item>
    </style>

    <style name="Session.Lib.Theme" parent="SessionLibTheme"/>

    <declare-styleable name="SessionLib">
        <attr name="sessionLibBackground" format="reference|color" />
        <attr name="sessionLibSmallViewBackground" format="reference|color" />
        <attr name="sessionLibIconClose" format="reference" />
        <attr name="sessionLibIconLogo" format="reference" />
        <attr name="sessionLibIconEndSession" format="reference" />
        <attr name="sessionLibIconReward" format="reference" />
        <attr name="sessionLibIconMilestoneReward" format="reference" />
        <attr name="sessionLibIconLevelUp" format="reference" />
        <attr name="sessionLibIconNightSessionLevelUp" format="reference" />
        <attr name="sessionLibIconRevenueEarnMore" format="reference" />
        <attr name="sessionLibIconRevenueDownloadFeature" format="reference" />
        <attr name="sessionLibIconRevenueReferralProgram" format="reference" />

        <attr name="sessionLibSeparator" format="reference" />
        <attr name="sessionLibNightSessionBackground" format="reference|color" />
        <attr name="sessionLibHighlightPrimaryColor" format="color" />
        <attr name="sessionLibHighlightSecondaryColor" format="color" />
        <attr name="sessionLibNightSessionListBackground" format="reference|color" />
        <attr name="sessionLibNightSessionIconChargeUp" format="reference|color" />
        <attr name="sessionLibNightSessionIconDoubleEarning" format="reference|color" />
        <attr name="sessionLibHighlightBoldFontFamily" format="reference" />
        <attr name="sessionLibNewAppsListBackground" format="reference|color" />
    </declare-styleable>



</resources>
