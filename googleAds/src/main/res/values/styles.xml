<?xml version="1.0" encoding="utf-8"?>
<resources>



    <style name="Theme.Chirag.Revenue.Lib" parent="Theme.Material3.Light.NoActionBar"/>

    <style name="Chirag.Revenue.Lib.Theme" parent="ChiragRevenueLibTheme"/>

    <style name="AdAttribution">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">left</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">12sp</item>
        <item name="android:text">@string/ad_attribution</item>
        <item name="android:background">@color/color_ffcc66</item>
        <item name="android:width">15dp</item>
        <item name="android:height">15dp</item>
    </style>

    <style name="Widget.MyApp.LoadingCard" parent="">
        <item name="cardBackgroundColor">?attr/customCardBackgroundColor</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="dialogCornerRadius">16dp</item>

        <!-- Transparent background if needed -->
        <item name="android:windowBackground">@android:color/transparent</item>

        <!-- Keep dialog floating -->
<!--        <item name="android:windowIsFloating">true</item>-->
        <item name="android:windowMinWidthMajor">50%</item>
        <item name="android:windowMinWidthMinor">50%</item>
        <!-- Optional: avoid full screen width -->
        <item name="android:layout_width">wrap_content</item>
        <item name="cardElevation">4dp</item>
    </style>

    <!-- Text style -->
    <style name="Text.MyApp.LoadingMessage" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/customTextColor</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="Chirag.Revenue.Lib.Dialog.Animation" parent="">
        <item name="android:windowEnterAnimation">@anim/chirag_revenue_lib_dialog_enter</item>
        <item name="android:windowExitAnimation">@anim/chirag_revenue_lib_dialog_exit</item>
    </style>


    <style name="ChiragRevenueLibTheme" parent="Theme.Chirag.Revenue.Lib">
        <item name="revenueLibBackground">@drawable/chirag_revenue_lib_window_background</item>
        <item name="revenueLibIconClose">@drawable/chirag_revenue_lib_close</item>
        <item name="revenueLibIconLogo">@drawable/chirag_revenue_lib_app_logo</item>

    </style>


    <declare-styleable name="RevenueLib">
        <attr name="revenueLibBackground" format="reference|color" />
        <attr name="revenueLibIconClose" format="reference" />
        <attr name="revenueLibIconLogo" format="reference" />
    </declare-styleable>


</resources>
