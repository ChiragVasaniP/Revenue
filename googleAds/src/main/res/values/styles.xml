<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AdAttribution">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">left</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">12sp</item>
        <item name="android:text">@string/ad_attribution</item>
        <item name="android:background">@color/color_ffcc66</item>
        <item name="android:width">15dp</item>
        <item name="android:height">15dp</item>
    </style>

    <!-- Add to your styles.xml -->
    <style name="RoundedDialogTheme" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <!-- Rounded corners -->
        <item name="dialogCornerRadius">16dp</item>

        <!-- Transparent background if needed -->
        <item name="android:windowBackground">@android:color/transparent</item>

        <!-- Keep dialog floating -->
        <item name="android:windowIsFloating">true</item>

        <!-- Optional: avoid full screen width -->
        <item name="android:layout_width">wrap_content</item>
    </style>


    <style name="Widget.MyApp.LoadingCard" parent="">
        <item name="cardBackgroundColor">?attr/customCardBackgroundColor</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="dialogCornerRadius">16dp</item>

        <!-- Transparent background if needed -->
        <item name="android:windowBackground">@android:color/transparent</item>

        <!-- Keep dialog floating -->
<!--        <item name="android:windowIsFloating">true</item>-->
        <item name="android:windowMinWidthMajor">50%</item>
        <item name="android:windowMinWidthMinor">50%</item>
        <!-- Optional: avoid full screen width -->
        <item name="android:layout_width">wrap_content</item>
        <item name="cardElevation">4dp</item>
    </style>

    <!-- Text style -->
    <style name="Text.MyApp.LoadingMessage" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/customTextColor</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="ThemeOverlay.GoogleAds.GenericDialog" parent="">
        <item name="genericDialogThemeOverlay">@style/ThemeOverlay.GoogleAds.GenericDialog</item>
        <item name="genericDialogSurfaceColor">#F8FAFC</item>
        <item name="genericDialogTitleTextColor">#0F172A</item>
        <item name="genericDialogDescriptionTextColor">#475569</item>
        <item name="genericDialogIconBackgroundColor">#7F1D1D</item>
        <item name="genericDialogPositiveButtonColor">#DC2626</item>
        <item name="genericDialogPositiveButtonTextColor">@android:color/white</item>
        <item name="genericDialogNegativeButtonColor">#E2E8F0</item>
        <item name="genericDialogNegativeButtonTextColor">#0F172A</item>
        <item name="genericDialogIconTintColor">@android:color/white</item>
    </style>

    <attr name="customCardBackgroundColor" format="color" />
    <attr name="customProgressColor" format="color" />
    <attr name="customTrackColor" format="color" />
    <attr name="customTextColor" format="color" />
    <attr name="genericDialogThemeOverlay" format="reference" />
    <attr name="genericDialogSurfaceColor" format="color" />
    <attr name="genericDialogTitleTextColor" format="color" />
    <attr name="genericDialogDescriptionTextColor" format="color" />
    <attr name="genericDialogIconBackgroundColor" format="color" />
    <attr name="genericDialogIconTintColor" format="color" />
    <attr name="genericDialogPositiveButtonColor" format="color" />
    <attr name="genericDialogPositiveButtonTextColor" format="color" />
    <attr name="genericDialogNegativeButtonColor" format="color" />
    <attr name="genericDialogNegativeButtonTextColor" format="color" />
</resources>
